# Copy this file to .env and adjust values if needed.

# Airflow runtime UID (on Windows/WSL keep default 50000)
AIRFLOW_UID=50000

# OLTP PostgreSQL (accessed from host on localhost:5433, from Airflow as postgres-oltp:5432)
OLTP_USER=logistics
OLTP_PASSWORD=logistics
OLTP_DB=logistics

# MinIO credentials (console on http://localhost:9001)
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=logistics-raw
